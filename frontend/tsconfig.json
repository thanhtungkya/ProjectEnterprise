{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "jsx": "preserve",
    "paths": {
      "@/*": ["./src/*"]
    },
    "strict": false,
    "noEmit": true
  },
  "include": ["src", "public"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
