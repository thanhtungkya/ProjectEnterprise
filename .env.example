# Database Connection String from Neon.tech or local PostgreSQL
# Format: postgresql://user:password@host:port/database
# For local: postgresql://postgres:password@localhost:5432/messenger
# For Neon: postgresql://user:password@your-neon-endpoint/database?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/messenger"

# Environment
NODE_ENV=development
PORT=3000

# JWT Secret for token signing
JWT_SECRET="secure-enterprise-secret-change-in-production"

# API Keys (optional)
GEMINI_API_KEY=""
